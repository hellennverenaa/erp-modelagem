# ══════════════════════════════════════════════════════════════════════════
# .env.example — ERP Chão de Fábrica v4.0
# Copie este arquivo para um arquivo chamado `.env` na mesma pasta e
# configure as chaves e credenciais reais do seu ambiente local.
# ══════════════════════════════════════════════════════════════════════════

# ── Configurações Gerais do Node ──
NODE_ENV=production
ERP_PORT=3001

# ── Banco de Dados (PostgreSQL Dedicado do ERP) ──
# Dentro do docker-compose, o host deve ser o nome do serviço: erp-postgres
DB_HOST=erp-postgres
DB_PORT=5432
DB_NAME=erp_modelagem
DB_USER=postgres
# Insira uma senha forte para o banco do ERP (deve coincidir com a do .env do Compose)
DB_PASS=ALTERAR_PARA_UMA_SENHA_FORTE_DO_POSTGRES

# Porta do banco de dados exposta para o host (para usar no DBeaver/pgAdmin)
DB_EXTERNAL_PORT=5433

# ── Cache e Rate Limiting (Redis Dedicado) ──
# Dentro do docker-compose, o host deve ser o nome do serviço: erp-redis
REDIS_HOST=erp-redis
REDIS_PORT=6379
# Insira uma senha para autenticação no Redis
REDIS_PASS=ALTERAR_PARA_UMA_SENHA_FORTE_DO_REDIS
# Porta do Redis exposta para o host (para conexão local)
REDIS_EXTERNAL_PORT=6380

# ── Segurança e Autenticação (JWT) ──
# ATENÇÃO CRÍTICA: Para o Single Sign-On (SSO) com o ecossistema legado DASS,
# esta variável JWT_SECRET DEVE ter exatamente o mesmo valor definido no serviço 
# dass_auth_service (por exemplo, "chave-segredo" em ambiente de desenvolvimento local).
JWT_SECRET=mesmo_segredo_do_dass_auth_service
JWT_REFRESH_SECRET=gerar_um_segredo_forte_para_o_refresh_token
JWT_ACCESS_TTL=3600
JWT_REFRESH_TTL=604800

# ── Integrações com Serviços Legados ──
# URL do dass_auth_service dentro da rede Docker dass_private (resolvida pelo nome do container)
DASS_AUTH_URL=http://main-service:2399

# URL da API de usuários do Hendrius executando diretamente na máquina local (host)
# O Docker resolve 'host.docker.internal' para o IP do seu computador host.
SOBRACORTE_API_URL=http://host.docker.internal:3333

# ── Configurações de CORS (origens autorizadas, separadas por vírgula) ──
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Upload de Arquivos (Fotos de ocorrências de gargalo e dossiês) ──
UPLOAD_DIR=/app/uploads
UPLOAD_MAX_SIZE_MB=10

# ── Serviço de E-mail (SMTP) para Disparo do Checklist (Genkit flows) ──
SMTP_HOST=smtp.seudominio.com
SMTP_PORT=587
SMTP_USER=erp@seudominio.com
SMTP_PASS=senha_do_servidor_smtp

# ── Configurações de IA (Google GenAI / Gemini) ──
# Chave da API da Google AI Studio para geração automática do Dossiê do Modelo
GOOGLE_GENAI_API_KEY=sua_chave_do_google_genai_aqui
